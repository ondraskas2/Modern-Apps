<?xml version="1.0" encoding="utf-8"?>
<!-- updatePeriodMillis is 0: the framework AnalogClock ticks its own hands, so the
     widget never needs an AppWidgetManager refresh to stay current. -->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="110dp"
    android:minHeight="110dp"
    android:targetCellWidth="2"
    android:targetCellHeight="2"
    android:updatePeriodMillis="0"
    android:initialLayout="@layout/analog_clock_widget"
    android:previewLayout="@layout/analog_clock_widget"
    android:description="@string/analog_clock_widget_description"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen" />
