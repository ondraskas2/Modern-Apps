<?xml version="1.0" encoding="utf-8"?>
<!-- The blob background is drawn by an ImageView with scaleType="fitCenter" (instead of
     as the root's stretchable background) so it always stays a centered 1:1 blob, as large
     as possible, even when the widget is resized into a non-square rectangle. The framework
     AnalogClock likewise scales its square dial centered, so the two stay aligned. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/analog_clock_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="10dp">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/analog_clock_widget_background"
        android:scaleType="fitCenter"
        android:contentDescription="@null" />

    <AnalogClock
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:dial="@drawable/analog_clock_dial"
        android:hand_hour="@drawable/analog_clock_hand_hour"
        android:hand_minute="@drawable/analog_clock_hand_minute"
        android:hand_second="@drawable/analog_clock_hand_second" />

</FrameLayout>
