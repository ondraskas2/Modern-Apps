<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/analog_clock_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/analog_clock_widget_background"
    android:padding="10dp">

    <AnalogClock
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:dial="@drawable/analog_clock_dial"
        android:hand_hour="@drawable/analog_clock_hand_hour"
        android:hand_minute="@drawable/analog_clock_hand_minute"
        android:hand_second="@drawable/analog_clock_hand_second" />

</FrameLayout>
