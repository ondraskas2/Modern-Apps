<?xml version="1.0" encoding="utf-8"?>
<!-- Second "hand" rendered as a filled DOT (not a line). The circle sits near the top
     of an otherwise transparent drawable; AnalogClock rotates the whole drawable about
     the dial center (100,100), so the dot orbits the dial once per minute. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="200dp"
    android:height="200dp"
    android:viewportWidth="200"
    android:viewportHeight="200">
    <path
        android:fillColor="@android:color/system_accent3_100"
        android:pathData="M91,42 a9,9 0 1,0 18,0 a9,9 0 1,0 -18,0 Z" />
</vector>
