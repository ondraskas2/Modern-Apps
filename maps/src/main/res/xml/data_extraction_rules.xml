<?xml version="1.0" encoding="utf-8"?>
<!--
  Maps-specific backup/transfer rules. The shared library rules include
  `external` storage, but for this module that domain holds tens to hundreds
  of megabytes of downloaded offline-zone data (zone_*.pmtiles,
  nodes_zone_*.bin, edges_zone_*.bin, transit_voyages_zone_*.bin,
  transit_attributes_zone_*.bin, amenities.db, metadata.bin,
  road_names.bin, intermediate.bin, world_z0-6.pmtiles).

  Cloud Auto Backup has a 25 MB quota; including these files would blow past
  it on the first sync and silently disable backup for the whole app. They're
  re-downloadable from data.vayunmathur.com on demand, so we exclude them.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="root" path="." />
        <include domain="file" path="." />
        <include domain="database" path="." />
        <include domain="sharedpref" path="." />
        <!-- external: deliberately excluded — see comment above. -->
    </cloud-backup>
    <device-transfer>
        <include domain="root" path="." />
        <include domain="file" path="." />
        <include domain="database" path="." />
        <include domain="sharedpref" path="." />
        <!-- external IS included for device transfer so a new phone gets the
             user's already-downloaded zones rather than re-downloading them. -->
        <include domain="external" path="." />
    </device-transfer>
</data-extraction-rules>
